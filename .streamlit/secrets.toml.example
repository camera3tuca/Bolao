# Modelo de configuração de secrets para o Streamlit.
#
# 1. Copie este arquivo para `.streamlit/secrets.toml` (local) OU cole o
#    conteúdo em "App settings -> Secrets" no Streamlit Community Cloud.
# 2. Substitua [YOUR-PASSWORD] pela senha do banco do seu projeto Supabase.
#
# IMPORTANTE: o Supabase desativou o IPv4 direto. Use a URL do
# **Connection Pooler** (host `aws-0-<regiao>.pooler.supabase.com`), e não a
# URL direta (`db.<ref>.supabase.co`). O Streamlit Cloud normalmente só tem
# IPv4, então a URL direta falha.
#
# Onde encontrar: Supabase -> Project Settings -> Database -> Connection
# pooling. Use o "Session pooler" (porta 5432) para apps persistentes como
# este; o "Transaction pooler" (porta 6543) também funciona.

# URL do Session Pooler (recomendada). Troque a região se o seu projeto não
# estiver em us-west-2. O app adiciona sslmode=require automaticamente.
DATABASE_URL = "postgresql://postgres.lueqftezoesihyecftzq:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# Opcional: se você preferir manter a URL DIRETA (db.<ref>.supabase.co), o app
# a converte automaticamente para o pooler usando esta região e, se a região
# estiver errada ("Tenant or user not found"), tenta outras automaticamente.
# SUPABASE_REGION = "us-west-2"

# Opcional: senha do painel de administração (padrão: 5075).
# ADMIN_PASSWORD = "troque-esta-senha"
