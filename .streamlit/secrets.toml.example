# Modelo de configuração de secrets para o Streamlit.
#
# 1. Copie este arquivo para `.streamlit/secrets.toml` (local) OU cole o
#    conteúdo em "App settings -> Secrets" no Streamlit Community Cloud.
# 2. Substitua [YOUR-PASSWORD] pela senha do banco.
#
# NUNCA faça commit da senha real: este arquivo é só um modelo. O
# `.streamlit/secrets.toml` de verdade está no .gitignore.

# =========================================================
# OPÇÃO RECOMENDADA: Neon (https://neon.tech)
# =========================================================
# O endpoint com "-pooler" do Neon responde por IPv4 (funciona no Streamlit
# Cloud) e já traz sslmode=require. Basta colar a string; não precisa de
# conversão de pooler nem região.
#
# Onde achar: painel do Neon -> Connection Details -> ative "Connection
# pooling" -> copie a Connection string (host termina em
# "-pooler.<regiao>.aws.neon.tech").
DATABASE_URL = "postgresql://neondb_owner:[YOUR-PASSWORD]@ep-xxxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# =========================================================
# ALTERNATIVA: Supabase (Connection Pooler)
# =========================================================
# O Supabase desativou o IPv4 direto. Use o Connection Pooler (host
# `aws-0-<regiao>.pooler.supabase.com`), e não a URL direta
# (`db.<ref>.supabase.co`). Onde achar: Project Settings -> Database ->
# Connection pooling (Session pooler, porta 5432).
# DATABASE_URL = "postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres"
#
# Se você mantiver a URL DIRETA do Supabase, o app a converte automaticamente
# para o pooler; ajuste a região se necessário (padrão us-west-2):
# SUPABASE_REGION = "us-west-2"

# =========================================================
# Opcional
# =========================================================
# Senha do painel de administração (padrão: 5075).
# ADMIN_PASSWORD = "troque-esta-senha"
